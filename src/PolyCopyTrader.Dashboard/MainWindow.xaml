<Window x:Class="PolyCopyTrader.Dashboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding AppTitle}"
        Height="760"
        Width="1220"
        MinHeight="620"
        MinWidth="980"
        Background="#F4F6F8">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#1F2937" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="MinWidth" Value="96" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="10,0" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="30" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="RowHeight" Value="28" />
            <Setter Property="AlternatingRowBackground" Value="#F9FAFB" />
            <Setter Property="BorderBrush" Value="#D1D5DB" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="True">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="{Binding AppTitle}"
                           FontSize="24"
                           FontWeight="SemiBold" />
                <TextBlock Text="{Binding Summary}"
                           Margin="0,4,0,0"
                           Foreground="#4B5563" />
            </StackPanel>

            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <TextBlock Text="Mode"
                           VerticalAlignment="Center"
                           Foreground="#6B7280" />
                <TextBlock Text="{Binding Mode}"
                           Margin="8,0,20,0"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold" />
                <TextBlock Text="Service"
                           VerticalAlignment="Center"
                           Foreground="#6B7280" />
                <TextBlock Text="{Binding ServiceStatus}"
                           Margin="8,0,20,0"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold" />
                <Button Content="Refresh"
                        Command="{Binding RefreshCommand}" />
            </StackPanel>
        </DockPanel>

        <DockPanel Grid.Row="1" Margin="0,14,0,12">
            <WrapPanel DockPanel.Dock="Left">
                <Button Content="Pause"
                        Command="{Binding PauseScanningCommand}" />
                <Button Content="Kill switch"
                        Command="{Binding KillSwitchCommand}" />
                <Button Content="Resume"
                        Command="{Binding ResumeScanningCommand}" />
                <Button Content="Pause paper"
                        Command="{Binding PausePaperTradingCommand}" />
                <Button Content="Resume paper"
                        Command="{Binding ResumePaperTradingCommand}" />
                <Button Content="Pause live"
                        Command="{Binding PauseLiveTradingCommand}" />
                <Button Content="Resume live"
                        Command="{Binding ResumeLiveTradingCommand}" />
                <Button Content="Cancel live"
                        Command="{Binding CancelAllLiveOrdersCommand}" />
                <Button Content="Clear kill"
                        Command="{Binding ClearKillSwitchCommand}" />
                <TextBox Width="190"
                         Text="{Binding PinnedAssetId, UpdateSourceTrigger=PropertyChanged}" />
                <Button Content="Pin asset"
                        Command="{Binding PinAssetCommand}" />
                <Button Content="Unpin asset"
                        Command="{Binding UnpinAssetCommand}" />
                <Button Content="Disable trader"
                        Command="{Binding DisableTraderCommand}" />
                <Button Content="Enable trader"
                        Command="{Binding EnableTraderCommand}" />
                <Button Content="Cancel order"
                        Command="{Binding CancelPaperOrderCommand}" />
                <Button Content="Clear logs"
                        Command="{Binding ClearLogsCommand}" />
                <Button Content="Export CSV"
                        Command="{Binding ExportCsvCommand}" />
            </WrapPanel>
            <StackPanel DockPanel.Dock="Right"
                        HorizontalAlignment="Right">
                <TextBlock Text="{Binding StorageStatus}"
                           HorizontalAlignment="Right"
                           Foreground="#4B5563" />
                <TextBlock Text="{Binding CommandStatus}"
                           Margin="0,3,0,0"
                           HorizontalAlignment="Right"
                           Foreground="#6B7280" />
            </StackPanel>
        </DockPanel>

        <TabControl Grid.Row="2">
            <TabItem Header="Overview">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Overview}" Margin="0,12,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="3" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White"
                                        BorderBrush="#D1D5DB"
                                        BorderThickness="1"
                                        Padding="12"
                                        Margin="0,0,12,12">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="#6B7280" />
                                        <TextBlock Text="{Binding Value}"
                                                   Margin="0,6,0,0"
                                                   FontSize="16"
                                                   FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Watchlist">
                <DataGrid ItemsSource="{Binding Watchlist}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Trader" Binding="{Binding TraderName}" Width="140" />
                        <DataGridTextColumn Header="Wallet" Binding="{Binding Wallet}" Width="260" />
                        <DataGridCheckBoxColumn Header="Enabled" Binding="{Binding Enabled}" Width="70" />
                        <DataGridTextColumn Header="Categories" Binding="{Binding AllowedCategories}" Width="160" />
                        <DataGridTextColumn Header="Last scan UTC" Binding="{Binding LastSuccessfulScanUtc}" Width="150" />
                        <DataGridTextColumn Header="Last trade UTC" Binding="{Binding LastSeenTradeUtc}" Width="150" />
                        <DataGridTextColumn Header="Fetched" Binding="{Binding TradesFetched}" Width="80" />
                        <DataGridTextColumn Header="New" Binding="{Binding NewTradesStored}" Width="70" />
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120" />
                        <DataGridTextColumn Header="Last error" Binding="{Binding LastError}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Leader Trades">
                <DataGrid ItemsSource="{Binding LeaderTrades}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Timestamp UTC" Binding="{Binding TimestampUtc}" Width="150" />
                        <DataGridTextColumn Header="Trader" Binding="{Binding Trader}" Width="140" />
                        <DataGridTextColumn Header="Market" Binding="{Binding Market}" Width="260" />
                        <DataGridTextColumn Header="Outcome" Binding="{Binding Outcome}" Width="90" />
                        <DataGridTextColumn Header="Side" Binding="{Binding Side}" Width="70" />
                        <DataGridTextColumn Header="Price" Binding="{Binding LeaderPrice}" Width="80" />
                        <DataGridTextColumn Header="Size" Binding="{Binding Size}" Width="90" />
                        <DataGridTextColumn Header="Cash" Binding="{Binding CashValueUsd}" Width="90" />
                        <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="100" />
                        <DataGridTextColumn Header="Tx hash" Binding="{Binding TransactionHash}" Width="240" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Signals">
                <DataGrid ItemsSource="{Binding Signals}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Timestamp UTC" Binding="{Binding TimestampUtc}" Width="150" />
                        <DataGridTextColumn Header="Trader" Binding="{Binding Trader}" Width="170" />
                        <DataGridTextColumn Header="Market" Binding="{Binding Market}" Width="210" />
                        <DataGridTextColumn Header="Outcome" Binding="{Binding Outcome}" Width="90" />
                        <DataGridTextColumn Header="Score" Binding="{Binding Score}" Width="70" />
                        <DataGridCheckBoxColumn Header="Accepted" Binding="{Binding Accepted}" Width="80" />
                        <DataGridTextColumn Header="Decision" Binding="{Binding DecisionCode}" Width="160" />
                        <DataGridTextColumn Header="Reasons" Binding="{Binding ReasonCodes}" Width="220" />
                        <DataGridTextColumn Header="Leader" Binding="{Binding LeaderPrice}" Width="80" />
                        <DataGridTextColumn Header="Bid" Binding="{Binding BestBid}" Width="80" />
                        <DataGridTextColumn Header="Ask" Binding="{Binding BestAsk}" Width="80" />
                        <DataGridTextColumn Header="Spread" Binding="{Binding SpreadAbs}" Width="80" />
                        <DataGridTextColumn Header="Spread %" Binding="{Binding SpreadPct}" Width="80" />
                        <DataGridTextColumn Header="Lag" Binding="{Binding LagSeconds}" Width="70" />
                        <DataGridTextColumn Header="Paper price" Binding="{Binding ProposedPaperPrice}" Width="90" />
                        <DataGridTextColumn Header="Paper size" Binding="{Binding ProposedSizeShares}" Width="90" />
                        <DataGridTextColumn Header="Paper notional" Binding="{Binding ProposedNotionalUsd}" Width="110" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Paper Orders">
                <DataGrid ItemsSource="{Binding PaperOrders}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100" />
                        <DataGridTextColumn Header="Side" Binding="{Binding Side}" Width="70" />
                        <DataGridTextColumn Header="Market" Binding="{Binding Market}" Width="220" />
                        <DataGridTextColumn Header="Outcome" Binding="{Binding Outcome}" Width="90" />
                        <DataGridTextColumn Header="Price" Binding="{Binding Price}" Width="80" />
                        <DataGridTextColumn Header="Shares" Binding="{Binding SizeShares}" Width="90" />
                        <DataGridTextColumn Header="Notional" Binding="{Binding NotionalUsd}" Width="90" />
                        <DataGridTextColumn Header="Created UTC" Binding="{Binding CreatedUtc}" Width="150" />
                        <DataGridTextColumn Header="Expires UTC" Binding="{Binding ExpiresUtc}" Width="150" />
                        <DataGridTextColumn Header="Filled UTC" Binding="{Binding FilledUtc}" Width="150" />
                        <DataGridTextColumn Header="TTL" Binding="{Binding TtlRemaining}" Width="80" />
                        <DataGridTextColumn Header="Signal id" Binding="{Binding SignalId}" Width="260" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Paper Positions">
                <DataGrid ItemsSource="{Binding PaperPositions}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Market" Binding="{Binding Market}" Width="240" />
                        <DataGridTextColumn Header="Outcome" Binding="{Binding Outcome}" Width="90" />
                        <DataGridTextColumn Header="Size" Binding="{Binding SizeShares}" Width="90" />
                        <DataGridTextColumn Header="Average" Binding="{Binding AveragePrice}" Width="90" />
                        <DataGridTextColumn Header="Bid" Binding="{Binding CurrentBid}" Width="80" />
                        <DataGridTextColumn Header="Ask" Binding="{Binding CurrentAsk}" Width="80" />
                        <DataGridTextColumn Header="Value" Binding="{Binding EstimatedValueUsd}" Width="100" />
                        <DataGridTextColumn Header="Unrealized PnL" Binding="{Binding UnrealizedPnlUsd}" Width="120" />
                        <DataGridTextColumn Header="Realized PnL" Binding="{Binding RealizedPnlUsd}" Width="110" />
                        <DataGridTextColumn Header="Source trader" Binding="{Binding SourceTrader}" Width="160" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Dry Run Orders">
                <DataGrid ItemsSource="{Binding DryRunOrders}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Created UTC" Binding="{Binding TimestampUtc}" Width="150" />
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120" />
                        <DataGridTextColumn Header="Side" Binding="{Binding Side}" Width="70" />
                        <DataGridTextColumn Header="Asset" Binding="{Binding Asset}" Width="260" />
                        <DataGridTextColumn Header="Outcome" Binding="{Binding Outcome}" Width="90" />
                        <DataGridTextColumn Header="Price" Binding="{Binding Price}" Width="80" />
                        <DataGridTextColumn Header="Shares" Binding="{Binding SizeShares}" Width="90" />
                        <DataGridTextColumn Header="Notional" Binding="{Binding NotionalUsd}" Width="90" />
                        <DataGridTextColumn Header="Order type" Binding="{Binding OrderType}" Width="90" />
                        <DataGridTextColumn Header="Validation" Binding="{Binding ValidationSummary}" Width="260" />
                        <DataGridTextColumn Header="Signal id" Binding="{Binding SignalId}" Width="260" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Live Orders">
                <DataGrid ItemsSource="{Binding LiveOrders}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Created UTC" Binding="{Binding CreatedUtc}" Width="150" />
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="110" />
                        <DataGridTextColumn Header="Order id" Binding="{Binding OrderId}" Width="230" />
                        <DataGridTextColumn Header="Side" Binding="{Binding Side}" Width="70" />
                        <DataGridTextColumn Header="Asset" Binding="{Binding Asset}" Width="240" />
                        <DataGridTextColumn Header="Outcome" Binding="{Binding Outcome}" Width="90" />
                        <DataGridTextColumn Header="Price" Binding="{Binding Price}" Width="80" />
                        <DataGridTextColumn Header="Shares" Binding="{Binding SizeShares}" Width="90" />
                        <DataGridTextColumn Header="Notional" Binding="{Binding NotionalUsd}" Width="90" />
                        <DataGridTextColumn Header="Type" Binding="{Binding OrderType}" Width="70" />
                        <DataGridTextColumn Header="Expires UTC" Binding="{Binding ExpiresUtc}" Width="150" />
                        <DataGridTextColumn Header="Response" Binding="{Binding ResponseStatus}" Width="110" />
                        <DataGridTextColumn Header="Filled" Binding="{Binding FilledSize}" Width="90" />
                        <DataGridTextColumn Header="Remaining" Binding="{Binding RemainingSize}" Width="90" />
                        <DataGridTextColumn Header="Cancel" Binding="{Binding CancelStatus}" Width="130" />
                        <DataGridTextColumn Header="Validation" Binding="{Binding ValidationSummary}" Width="260" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Live Events">
                <DataGrid ItemsSource="{Binding LiveTradingEvents}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Created UTC" Binding="{Binding TimestampUtc}" Width="150" />
                        <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="140" />
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90" />
                        <DataGridTextColumn Header="Details" Binding="{Binding Details}" Width="600" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Market Data">
                <DataGrid ItemsSource="{Binding MarketData}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Asset" Binding="{Binding AssetId}" Width="300" />
                        <DataGridTextColumn Header="Market" Binding="{Binding ConditionId}" Width="300" />
                        <DataGridTextColumn Header="Bid" Binding="{Binding BestBid}" Width="90" />
                        <DataGridTextColumn Header="Ask" Binding="{Binding BestAsk}" Width="90" />
                        <DataGridTextColumn Header="Spread" Binding="{Binding Spread}" Width="90" />
                        <DataGridTextColumn Header="Snapshot UTC" Binding="{Binding SnapshotUtc}" Width="160" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Analytics">
                <TabControl>
                    <TabItem Header="Daily">
                        <DataGrid ItemsSource="{Binding DailyReports}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="100" />
                                <DataGridTextColumn Header="Signals" Binding="{Binding SignalsObserved}" Width="80" />
                                <DataGridTextColumn Header="Accepted" Binding="{Binding SignalsAccepted}" Width="80" />
                                <DataGridTextColumn Header="Rejected" Binding="{Binding SignalsRejected}" Width="80" />
                                <DataGridTextColumn Header="Orders" Binding="{Binding PaperOrdersCreated}" Width="80" />
                                <DataGridTextColumn Header="Fills" Binding="{Binding PaperFills}" Width="70" />
                                <DataGridTextColumn Header="Expired" Binding="{Binding PaperExpiredOrders}" Width="80" />
                                <DataGridTextColumn Header="Paper PnL" Binding="{Binding PaperPnl}" Width="100" />
                                <DataGridTextColumn Header="Open exposure" Binding="{Binding OpenPaperExposure}" Width="120" />
                                <DataGridTextColumn Header="Top rejections" Binding="{Binding TopRejectionReasons}" Width="260" />
                                <DataGridTextColumn Header="API errors" Binding="{Binding ApiErrors}" Width="80" />
                                <DataGridTextColumn Header="Generated UTC" Binding="{Binding GeneratedUtc}" Width="150" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>

                    <TabItem Header="Traders">
                        <DataGrid ItemsSource="{Binding TraderPerformance}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Trader" Binding="{Binding Trader}" Width="220" />
                                <DataGridTextColumn Header="Signals" Binding="{Binding Signals}" Width="70" />
                                <DataGridTextColumn Header="Accept %" Binding="{Binding AcceptanceRatePct}" Width="80" />
                                <DataGridTextColumn Header="Fill %" Binding="{Binding FillRatePct}" Width="80" />
                                <DataGridTextColumn Header="Avg lag" Binding="{Binding AverageLagSeconds}" Width="80" />
                                <DataGridTextColumn Header="Avg leader" Binding="{Binding AverageLeaderPrice}" Width="90" />
                                <DataGridTextColumn Header="Avg proposed" Binding="{Binding AverageProposedPrice}" Width="100" />
                                <DataGridTextColumn Header="Price diff" Binding="{Binding AveragePriceDifference}" Width="90" />
                                <DataGridTextColumn Header="Paper PnL" Binding="{Binding PaperPnl}" Width="100" />
                                <DataGridTextColumn Header="PnL by category" Binding="{Binding PaperPnlByCategory}" Width="180" />
                                <DataGridTextColumn Header="Rejections" Binding="{Binding RejectionReasons}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>

                    <TabItem Header="Categories">
                        <DataGrid ItemsSource="{Binding CategoryPerformance}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="160" />
                                <DataGridTextColumn Header="Signals" Binding="{Binding Signals}" Width="80" />
                                <DataGridTextColumn Header="Accepted" Binding="{Binding Accepted}" Width="80" />
                                <DataGridTextColumn Header="Filled" Binding="{Binding Filled}" Width="80" />
                                <DataGridTextColumn Header="Paper PnL" Binding="{Binding PaperPnl}" Width="100" />
                                <DataGridTextColumn Header="Avg spread" Binding="{Binding AverageSpread}" Width="100" />
                                <DataGridTextColumn Header="Avg lag" Binding="{Binding AverageLagSeconds}" Width="100" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>

                    <TabItem Header="Execution">
                        <DataGrid ItemsSource="{Binding ExecutionQuality}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Created UTC" Binding="{Binding CreatedUtc}" Width="150" />
                                <DataGridTextColumn Header="Trader" Binding="{Binding Trader}" Width="180" />
                                <DataGridTextColumn Header="Asset" Binding="{Binding Asset}" Width="260" />
                                <DataGridTextColumn Header="Leader" Binding="{Binding LeaderPrice}" Width="80" />
                                <DataGridTextColumn Header="Proposed" Binding="{Binding ProposedPrice}" Width="80" />
                                <DataGridTextColumn Header="Fill" Binding="{Binding PaperFillPrice}" Width="80" />
                                <DataGridTextColumn Header="Prop-Leader" Binding="{Binding ProposedMinusLeader}" Width="90" />
                                <DataGridTextColumn Header="Fill-Prop" Binding="{Binding FillMinusProposed}" Width="90" />
                                <DataGridTextColumn Header="Lag" Binding="{Binding LagSeconds}" Width="70" />
                                <DataGridTextColumn Header="Spread" Binding="{Binding SpreadAtSignal}" Width="80" />
                                <DataGridTextColumn Header="Mid +1m" Binding="{Binding MidAfter1m}" Width="80" />
                                <DataGridTextColumn Header="Mid +5m" Binding="{Binding MidAfter5m}" Width="80" />
                                <DataGridTextColumn Header="Mid +30m" Binding="{Binding MidAfter30m}" Width="90" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>

                    <TabItem Header="Rejections">
                        <DataGrid ItemsSource="{Binding RejectionAnalysis}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Reason" Binding="{Binding ReasonCode}" Width="220" />
                                <DataGridTextColumn Header="Count" Binding="{Binding Count}" Width="80" />
                                <DataGridTextColumn Header="Rejected %" Binding="{Binding RejectedPct}" Width="100" />
                                <DataGridTextColumn Header="Last UTC" Binding="{Binding LastRejectedUtc}" Width="150" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>
                </TabControl>
            </TabItem>

            <TabItem Header="Risk">
                <DataGrid ItemsSource="{Binding RiskUsage}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Limit" Binding="{Binding Name}" Width="180" />
                        <DataGridTextColumn Header="Limit value" Binding="{Binding LimitUsd}" Width="120" />
                        <DataGridTextColumn Header="Used" Binding="{Binding UsedUsd}" Width="120" />
                        <DataGridTextColumn Header="Used %" Binding="{Binding UsedPct}" Width="100" />
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Diagnostics">
                <DataGrid ItemsSource="{Binding Diagnostics}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Check" Binding="{Binding Name}" Width="180" />
                        <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="*" />
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Runbook">
                <DataGrid ItemsSource="{Binding RunbookLinks}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Document" Binding="{Binding Document}" Width="180" />
                        <DataGridTextColumn Header="Path" Binding="{Binding Path}" Width="280" />
                        <DataGridTextColumn Header="Purpose" Binding="{Binding Purpose}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Logs">
                <DataGrid ItemsSource="{Binding Logs}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Time UTC" Binding="{Binding TimestampUtc}" Width="150" />
                        <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="90" />
                        <DataGridTextColumn Header="Component" Binding="{Binding Component}" Width="180" />
                        <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="420" />
                        <DataGridTextColumn Header="Details" Binding="{Binding Details}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>

        <DockPanel Grid.Row="3" Margin="0,10,0,0">
            <TextBlock DockPanel.Dock="Left"
                       Text="{Binding LastError}"
                       Foreground="#B91C1C" />
            <TextBlock DockPanel.Dock="Right"
                       HorizontalAlignment="Right"
                       Foreground="#6B7280">
                <Run Text="Last updated UTC: " />
                <Run Text="{Binding LastUpdatedUtc}" />
            </TextBlock>
        </DockPanel>
    </Grid>
</Window>

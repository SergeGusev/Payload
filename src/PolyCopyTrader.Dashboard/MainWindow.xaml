                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Checked UTC" Binding="{Binding CheckedUtc}" Width="150" />
                        <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="130" />
                        <DataGridTextColumn Header="Endpoint" Binding="{Binding Endpoint}" Width="130" />
                        <DataGridTextColumn Header="Host" Binding="{Binding Host}" Width="230" />
                        <DataGridTextColumn Header="TLS" Binding="{Binding Tls}" Width="170" />
                        <DataGridTextColumn Header="Pin" Binding="{Binding Pin}" Width="120" />
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90" />
                        <DataGridTextColumn Header="Subject" Binding="{Binding Subject}" Width="300" />
                        <DataGridTextColumn Header="Issuer" Binding="{Binding Issuer}" Width="300" />
                        <DataGridTextColumn Header="Valid to UTC" Binding="{Binding ValidToUtc}" Width="150" />
                        <DataGridTextColumn Header="Presented pin" Binding="{Binding PresentedPin}" Width="360" />
                        <DataGridTextColumn Header="Details" Binding="{Binding Details}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Runbook">
                <DataGrid ItemsSource="{Binding RunbookLinks}"
                          behaviors:DataGridSelectionPersistence.KeyProperties="Document,Path">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Document" Binding="{Binding Document}" Width="180" />
                        <DataGridTextColumn Header="Path" Binding="{Binding Path}" Width="280" />
                        <DataGridTextColumn Header="Purpose" Binding="{Binding Purpose}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Logs">
                <DataGrid ItemsSource="{Binding Logs}"
                          behaviors:DataGridSelectionPersistence.KeyProperties="TimestampUtc,Component,Message">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Time UTC" Binding="{Binding TimestampUtc}" Width="150" />
                        <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="90" />
                        <DataGridTextColumn Header="Component" Binding="{Binding Component}" Width="180" />
                        <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="420" />
                        <DataGridTextColumn Header="Details" Binding="{Binding Details}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Dashboard Errors">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top"
                                Orientation="Horizontal"
                                Margin="0,0,0,8">
                        <Button Content="Clear errors"
                                Command="{Binding ClearDashboardErrorsCommand}" />
                        <Button Content="Copy selected"
                                Command="{Binding CopySelectedDashboardErrorCommand}" />
                    </StackPanel>
                    <DataGrid ItemsSource="{Binding DashboardErrors}"
                              behaviors:DataGridSelectionPersistence.KeyProperties="TimestampUtc,Source,Message"
                              SelectedItem="{Binding SelectedDashboardError, Mode=TwoWay}"
                              RowHeight="NaN"
                              CanUserResizeRows="True"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              ClipboardCopyMode="IncludeHeader">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Time UTC" Binding="{Binding TimestampUtc}" Width="150" />
                            <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="160" />
                            <DataGridTemplateColumn Header="Message" Width="360">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Message, Mode=OneWay}"
                                                 Style="{StaticResource CopyableGridTextBox}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Details" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Details, Mode=OneWay}"
                                                 Style="{StaticResource CopyableGridTextBox}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>
        </TabControl>

        <DockPanel Grid.Row="4" Margin="0,10,0,0">
            <TextBlock DockPanel.Dock="Left"
                       Text="{Binding LastError}"
                       Foreground="#B91C1C" />
            <TextBlock DockPanel.Dock="Right"
                       HorizontalAlignment="Right"
                       Foreground="#6B7280">
                <Run Text="Last updated UTC: " />
                <Run Text="{Binding LastUpdatedUtc}" />
            </TextBlock>
        </DockPanel>
    </Grid>
</Window>

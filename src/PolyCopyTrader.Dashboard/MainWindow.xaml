<Window x:Class="PolyCopyTrader.Dashboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:behaviors="clr-namespace:PolyCopyTrader.Dashboard.Behaviors"
        mc:Ignorable="d"
        Title="{Binding AppTitle}"
        Height="760"
        Width="1220"
        MinHeight="620"
        MinWidth="980"
        Background="#F4F6F8">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#1F2937" />
            <Setter Property="FontSize" Value="13" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="MinWidth" Value="96" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="10,0" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="30" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="30" />
            <Setter Property="Margin" Value="8,0,20,0" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="RowHeight" Value="28" />
            <Setter Property="AlternatingRowBackground" Value="#F9FAFB" />
            <Setter Property="BorderBrush" Value="#D1D5DB" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="CopyableGridTextBox" TargetType="TextBox">
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="4,2" />
            <Setter Property="VerticalContentAlignment" Value="Top" />
            <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
            <Setter Property="VerticalScrollBarVisibility" Value="Disabled" />
        </Style>
        <DataTemplate x:Key="StrategyRecentGridTemplate">
            <DataGrid ItemsSource="{Binding}"
                      behaviors:DataGridSelectionPersistence.KeyProperties="Name">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="260" />
                    <DataGridTextColumn Header="Settles" Binding="{Binding SettledRunsCount}" Width="75" />
                    <DataGridTextColumn Header="Skipped" Binding="{Binding SkippedRunsCount}" Width="75" />
                    <DataGridTextColumn Header="Won" Binding="{Binding WonRunsCount}" Width="60" />
                    <DataGridTextColumn Header="Lost" Binding="{Binding LostRunsCount}" Width="60" />
                    <DataGridTextColumn Header="Realized" Binding="{Binding RealizedPnlUsd}" Width="85" />
                    <DataGridTextColumn Header="ClosedRoi" Binding="{Binding RoiPct}" Width="85" />
                    <DataGridTextColumn Header="Live settles" Binding="{Binding LiveSettledOrdersCount}" Width="90" />
                    <DataGridTextColumn Header="Live cond skip" Binding="{Binding LiveConditionSkippedOrdersCount}" Width="105" />
                    <DataGridTextColumn Header="Live tech skip" Binding="{Binding LiveTechnicalSkippedOrdersCount}" Width="105" />
                    <DataGridTextColumn Header="Live ignored" Binding="{Binding LiveIgnoredOrdersCount}" Width="95" />
                    <DataGridTextColumn Header="Live won" Binding="{Binding LiveWonOrdersCount}" Width="80" />
                    <DataGridTextColumn Header="Live lost" Binding="{Binding LiveLostOrdersCount}" Width="80" />
                    <DataGridTextColumn Header="Live realized" Binding="{Binding LiveRealizedPnlUsd}" Width="100" />
                    <DataGridTextColumn Header="Live ROI" Binding="{Binding LiveRoiPct}" Width="80" />
                    <DataGridTextColumn Header="Orders" Binding="{Binding OrdersCount}" Width="70" />
                    <DataGridTextColumn Header="Filled" Binding="{Binding FilledOrdersCount}" Width="70" />
                    <DataGridTextColumn Header="Expired" Binding="{Binding ExpiredOrdersCount}" Width="75" />
                    <DataGridTextColumn Header="Open" Binding="{Binding OpenOrdersCount}" Width="70" />
                    <DataGridTextColumn Header="Entered" Binding="{Binding EnteredRunsCount}" Width="75" />
                    <DataGridTextColumn Header="Win %" Binding="{Binding WinRatePct}" Width="70" />
                    <DataGridTextColumn Header="Filled cost" Binding="{Binding FilledCostUsd}" Width="90" />
                    <DataGridTextColumn Header="Avg fill" Binding="{Binding AvgFillPrice}" Width="80" />
                    <DataGridTextColumn Header="Avg delay s" Binding="{Binding AvgEntryDelaySeconds}" Width="90" />
                    <DataGridTextColumn Header="Max delay s" Binding="{Binding MaxEntryDelaySeconds}" Width="90" />
                    <DataGridTextColumn Header="Top skip" Binding="{Binding TopSkipReason}" Width="220" />
                    <DataGridTextColumn Header="Last order UTC" Binding="{Binding LastOrderUtc}" Width="150" />
                    <DataGridTextColumn Header="Last run UTC" Binding="{Binding LastRunUtc}" Width="150" />
                </DataGrid.Columns>
            </DataGrid>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                        Margin="0,0,16,0">
                <TextBlock Text="{Binding AppTitle}"
                           FontSize="24"
                           FontWeight="SemiBold" />
                <TextBlock Text="{Binding Summary}"
                           Margin="0,4,0,0"
                           Foreground="#4B5563"
                           TextTrimming="CharacterEllipsis"
                           TextWrapping="NoWrap"
                           ToolTip="{Binding Summary}" />
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <TextBlock Text="Database"
                           VerticalAlignment="Center"
                           Foreground="#6B7280" />
                <ComboBox Width="150"
                          ItemsSource="{Binding DatabaseSourceOptions}"
                          SelectedItem="{Binding SelectedDatabaseSource, Mode=TwoWay}" />
                <TextBlock Text="Mode"
                           VerticalAlignment="Center"
                           Foreground="#6B7280" />
                <TextBlock Text="{Binding Mode}"
                           Margin="8,0,20,0"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold" />
                <TextBlock Text="Service"
                           VerticalAlignment="Center"
                           Foreground="#6B7280" />
                <TextBlock Text="{Binding ServiceStatus}"
                           Margin="8,0,20,0"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold" />
                <Button Content="Refresh"
                        Command="{Binding RefreshCommand}" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="1"
                Background="{Binding ServiceBannerBackground}"
                BorderBrush="{Binding ServiceBannerBorderBrush}"
                BorderThickness="1"
                Padding="12,10"
                Margin="0,14,0,0">
            <StackPanel>
                <TextBlock Text="{Binding ServiceBannerTitle}"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{Binding ServiceBannerForeground}" />
                <TextBlock Text="{Binding ServiceBannerDetail}"
                           Margin="0,4,0,0"
                           TextWrapping="Wrap"
                           Foreground="{Binding ServiceBannerForeground}" />
            </StackPanel>
        </Border>

        <DockPanel Grid.Row="2" Margin="0,14,0,12">
            <WrapPanel DockPanel.Dock="Left">
                <Button Content="Pause"
                        Command="{Binding PauseScanningCommand}" />
                <Button Content="Kill switch"
                        Command="{Binding KillSwitchCommand}" />
                <Button Content="Resume"
                        Command="{Binding ResumeScanningCommand}" />
                <Button Content="Pause paper"
                        Command="{Binding PausePaperTradingCommand}" />
                <Button Content="Resume paper"
                        Command="{Binding ResumePaperTradingCommand}" />
                <Button Content="Pause live"
                        Command="{Binding PauseLiveTradingCommand}" />
                <Button Content="Resume live"
                        Command="{Binding ResumeLiveTradingCommand}" />
                <Button Content="Cancel live"
                        Command="{Binding CancelAllLiveOrdersCommand}" />
                <Button Content="Find traders"
                        Command="{Binding RefreshTraderDiscoveryCommand}" />
                <Button Content="Onchain sync"
                        Command="{Binding RefreshOnChainCommand}" />
                <Button Content="Enrich markets"
                        Command="{Binding RefreshOnChainMarketsCommand}" />
                <Button Content="Cancel onchain"
                        Command="{Binding CancelOnChainCommand}" />
                <Button Content="Clear kill"
                        Command="{Binding ClearKillSwitchCommand}" />
                <TextBox Width="190"
                         Text="{Binding PinnedAssetId, UpdateSourceTrigger=PropertyChanged}" />
                <Button Content="Pin asset"
                        Command="{Binding PinAssetCommand}" />
                <Button Content="Unpin asset"
                        Command="{Binding UnpinAssetCommand}" />
                <Button Content="Disable trader"
                        Command="{Binding DisableTraderCommand}" />
                <Button Content="Enable trader"
                        Command="{Binding EnableTraderCommand}" />
                <Button Content="Cancel order"
                        Command="{Binding CancelPaperOrderCommand}" />
                <Button Content="Clear logs"
                        Command="{Binding ClearLogsCommand}" />
                <Button Content="Clear errors"
                        Command="{Binding ClearDashboardErrorsCommand}" />
                <Button Content="Check certificates"
                        Command="{Binding CheckCertificatesCommand}" />
                <Button Content="Export CSV"
                        Command="{Binding ExportCsvCommand}" />
            </WrapPanel>
            <StackPanel DockPanel.Dock="Right"
                        HorizontalAlignment="Right">
                <TextBlock Text="{Binding StorageStatus}"
                           HorizontalAlignment="Right"
                           Foreground="#4B5563" />
                <TextBlock Text="{Binding CommandStatus}"
                           Margin="0,3,0,0"
                           HorizontalAlignment="Right"
                           Foreground="#6B7280" />
            </StackPanel>
        </DockPanel>

        <TabControl Grid.Row="3">
            <TabItem Header="Overview">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Overview}" Margin="0,12,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="3" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White"
                                        BorderBrush="#D1D5DB"
                                        BorderThickness="1"
                                        Padding="12"
                                        Margin="0,0,12,12">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="#6B7280" />
                                        <TextBlock Text="{Binding Value}"
                                                   Margin="0,6,0,0"
                                                   FontSize="16"
                                                   FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Strategies">
                <TabControl>
                    <TabItem Header="All">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top"
                                        Orientation="Horizontal"
                                        Margin="0,0,0,8">
                                <TextBlock Text="Category"
                                           VerticalAlignment="Center"
                                           Foreground="#6B7280" />
                                <ComboBox Width="300"
                                          Height="30"
                                          Margin="8,0,0,0"
                                          ItemsSource="{Binding StrategyCategoryOptions}"
                                          SelectedItem="{Binding SelectedStrategyCategory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <CheckBox Content="Only positive"
                                          IsChecked="{Binding ShowOnlyPositiveStrategies, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          VerticalAlignment="Center"
                                          Margin="4,0,0,0" />
                            </StackPanel>
                            <DataGrid ItemsSource="{Binding Strategies}"
                                      behaviors:DataGridSelectionPersistence.KeyProperties="StrategyId">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Name" Width="260">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Name, Mode=OneWay}"
                                             Style="{StaticResource CopyableGridTextBox}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Enabled" Width="70">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              Command="{Binding DataContext.SetStrategyEnabledCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                              CommandParameter="{Binding}"
                                              HorizontalAlignment="Center" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Live" Width="60">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding LiveStakes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              Command="{Binding DataContext.SetStrategyLiveStakesCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                              CommandParameter="{Binding}"
                                              HorizontalAlignment="Center" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Settled" Binding="{Binding SettledPositionsCount}" Width="80" />
                        <DataGridTextColumn Header="Skipped" Binding="{Binding SkippedRunsCount}" Width="70" />
                        <DataGridTextColumn Header="Won" Binding="{Binding WonPositionsCount}" Width="60" />
                        <DataGridTextColumn Header="Lost" Binding="{Binding LostPositionsCount}" Width="60" />
                        <DataGridTextColumn Header="Realized" Binding="{Binding RealizedPnlUsd}" Width="90" />
                        <DataGridTextColumn Header="Closed ROI" Binding="{Binding ClosedRoiPct}" Width="95" />
                        <DataGridTextColumn Header="Live settles" Binding="{Binding LiveSettledOrdersCount}" Width="90" />
                        <DataGridTextColumn Header="Live cond skip" Binding="{Binding LiveConditionSkippedOrdersCount}" Width="105" />
                        <DataGridTextColumn Header="Live tech skip" Binding="{Binding LiveTechnicalSkippedOrdersCount}" Width="105" />
                        <DataGridTextColumn Header="Live ignored" Binding="{Binding LiveIgnoredOrdersCount}" Width="95" />
                        <DataGridTextColumn Header="Live won" Binding="{Binding LiveWonOrdersCount}" Width="80" />
                        <DataGridTextColumn Header="Live lost" Binding="{Binding LiveLostOrdersCount}" Width="80" />
                        <DataGridTextColumn Header="Live realized" Binding="{Binding LiveRealizedPnlUsd}" Width="100" />
                        <DataGridTextColumn Header="Live ROI" Binding="{Binding LiveRoiPct}" Width="80" />
                        <DataGridTemplateColumn Header="Paper $" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding PaperStakeAmount, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                             HorizontalContentAlignment="Right"
                                             Padding="4,2" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Live $" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding LiveStakeAmount, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                             HorizontalContentAlignment="Right"
                                             Padding="4,2" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Live bal" Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding LiveAvailableBalance, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                             HorizontalContentAlignment="Right"
                                             Padding="4,2" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Save" Width="60">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Save"
                                            Command="{Binding DataContext.SaveStrategyStakeAmountsCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Orders" Binding="{Binding OrdersCount}" Width="70" />
                        <DataGridTextColumn Header="Filled" Binding="{Binding FilledOrdersCount}" Width="70" />
                        <DataGridTextColumn Header="Open orders" Binding="{Binding OpenOrdersCount}" Width="90" />
                        <DataGridTextColumn Header="Open pos" Binding="{Binding OpenPositionsCount}" Width="80" />
                        <DataGridTextColumn Header="Observed" Binding="{Binding ObservedRunsCount}" Width="80" />
                        <DataGridTextColumn Header="Entered" Binding="{Binding EnteredRunsCount}" Width="70" />
                        <DataGridTextColumn Header="Settled runs" Binding="{Binding SettledRunsCount}" Width="90" />
                        <DataGridTextColumn Header="Stake" Binding="{Binding StakeUsd}" Width="90" />
                        <DataGridTextColumn Header="Open unrealized" Binding="{Binding UnrealizedPnlUsd}" Width="110" />
                        <DataGridTextColumn Header="MtM PnL" Binding="{Binding TotalPnlUsd}" Width="90" />
                        <DataGridTextColumn Header="Win %" Binding="{Binding WinRatePct}" Width="70" />
                        <DataGridTextColumn Header="Loss %" Binding="{Binding LossRatePct}" Width="70" />
                        <DataGridTextColumn Header="Avg win" Binding="{Binding AvgWinPnlUsd}" Width="80" />
                        <DataGridTextColumn Header="Avg loss" Binding="{Binding AvgLossPnlUsd}" Width="80" />
                        <DataGridTextColumn Header="Profit factor" Binding="{Binding ProfitFactor}" Width="95" />
                        <DataGridTextColumn Header="Expectancy" Binding="{Binding ExpectancyPnlUsd}" Width="90" />
                        <DataGridTextColumn Header="MtM ROI %" Binding="{Binding RoiPct}" Width="80" />
                        <DataGridTextColumn Header="Avg delay s" Binding="{Binding AvgEntryDelaySeconds}" Width="90" />
                        <DataGridTextColumn Header="Max delay s" Binding="{Binding MaxEntryDelaySeconds}" Width="90" />
                        <DataGridTextColumn Header="Live orders" Binding="{Binding LiveOrdersCount}" Width="90" />
                        <DataGridTextColumn Header="Live filled" Binding="{Binding LiveFilledOrdersCount}" Width="90" />
                        <DataGridTextColumn Header="Live open" Binding="{Binding LiveOpenOrdersCount}" Width="80" />
                        <DataGridTextColumn Header="Live stake" Binding="{Binding LiveStakeUsd}" Width="90" />
                        <DataGridTextColumn Header="Live win %" Binding="{Binding LiveWinRatePct}" Width="80" />
                        <DataGridTextColumn Header="Live loss %" Binding="{Binding LiveLossRatePct}" Width="80" />
                        <DataGridTextColumn Header="Live avg win" Binding="{Binding LiveAvgWinPnlUsd}" Width="95" />
                        <DataGridTextColumn Header="Live avg loss" Binding="{Binding LiveAvgLossPnlUsd}" Width="100" />
                        <DataGridTextColumn Header="Live profit factor" Binding="{Binding LiveProfitFactor}" Width="120" />
                        <DataGridTextColumn Header="Live expectancy" Binding="{Binding LiveExpectancyPnlUsd}" Width="115" />
                        <DataGridTextColumn Header="Live last order UTC" Binding="{Binding LiveLastOrderUtc}" Width="150" />
                        <DataGridTextColumn Header="Live last settle UTC" Binding="{Binding LiveLastSettlementUtc}" Width="150" />
                        <DataGridTextColumn Header="Last order UTC" Binding="{Binding LastOrderUtc}" Width="150" />
                        <DataGridTextColumn Header="Last run UTC" Binding="{Binding LastRunUtc}" Width="150" />
                            </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </TabItem>
                    <TabItem Header="24 hours">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top"
                                        Orientation="Horizontal"
                                        Margin="0,0,0,8">
                                <TextBlock Text="Category"
                                           VerticalAlignment="Center"
                                           Foreground="#6B7280" />
                                <ComboBox Width="300"
                                          Height="30"
                                          Margin="8,0,0,0"
                                          ItemsSource="{Binding StrategyCategoryOptions}"
                                          SelectedItem="{Binding SelectedStrategy24HoursCategory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <CheckBox Content="Only positive"
                                          IsChecked="{Binding ShowOnlyPositiveStrategy24Hours, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          VerticalAlignment="Center"
                                          Margin="4,0,0,0" />
                            </StackPanel>
                            <ContentControl Content="{Binding StrategyRecent24Hours}"
                                            ContentTemplate="{StaticResource StrategyRecentGridTemplate}" />
                        </DockPanel>
                    </TabItem>
                    <TabItem Header="6 hours">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top"
                                        Orientation="Horizontal"
                                        Margin="0,0,0,8">
                                <TextBlock Text="Category"
                                           VerticalAlignment="Center"
                                           Foreground="#6B7280" />
                                <ComboBox Width="300"
                                          Height="30"
                                          Margin="8,0,0,0"
                                          ItemsSource="{Binding StrategyCategoryOptions}"
                                          SelectedItem="{Binding SelectedStrategy6HoursCategory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <CheckBox Content="Only positive"
                                          IsChecked="{Binding ShowOnlyPositiveStrategy6Hours, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          VerticalAlignment="Center"
                                          Margin="4,0,0,0" />
                            </StackPanel>
                            <ContentControl Content="{Binding StrategyRecent6Hours}"
                                            ContentTemplate="{StaticResource StrategyRecentGridTemplate}" />
                        </DockPanel>
                    </TabItem>
                    <TabItem Header="1 hour">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top"
                                        Orientation="Horizontal"
                                        Margin="0,0,0,8">
                                <TextBlock Text="Category"
                                           VerticalAlignment="Center"
                                           Foreground="#6B7280" />
                                <ComboBox Width="300"
                                          Height="30"
                                          Margin="8,0,0,0"
                                          ItemsSource="{Binding StrategyCategoryOptions}"
                                          SelectedItem="{Binding SelectedStrategy1HourCategory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <CheckBox Content="Only positive"
                                          IsChecked="{Binding ShowOnlyPositiveStrategy1Hour, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          VerticalAlignment="Center"
                                          Margin="4,0,0,0" />
                            </StackPanel>
                            <ContentControl Content="{Binding StrategyRecent1Hour}"
                                            ContentTemplate="{StaticResource StrategyRecentGridTemplate}" />
                        </DockPanel>
                    </TabItem>
                </TabControl>
            </TabItem>

            <TabItem Header="Watchlist">
                <DataGrid ItemsSource="{Binding Watchlist}"
                          behaviors:DataGridSelectionPersistence.KeyProperties="Wallet">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Trader" Binding="{Binding TraderName}" Width="140" />
                        <DataGridTextColumn Header="Wallet" Binding="{Binding Wallet}" Width="260" />
                        <DataGridCheckBoxColumn Header="Enabled" Binding="{Binding Enabled}" Width="70" />
                        <DataGridTextColumn Header="Categories" Binding="{Binding AllowedCategories}" Width="160" />
                        <DataGridTextColumn Header="Last scan UTC" Binding="{Binding LastSuccessfulScanUtc}" Width="150" />
                        <DataGridTextColumn Header="Last trade UTC" Binding="{Binding LastSeenTradeUtc}" Width="150" />
                        <DataGridTextColumn Header="Fetched" Binding="{Binding TradesFetched}" Width="80" />
                        <DataGridTextColumn Header="New" Binding="{Binding NewTradesStored}" Width="70" />
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120" />
                        <DataGridTextColumn Header="Last error" Binding="{Binding LastError}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Trader Discovery">
                <DataGrid ItemsSource="{Binding TraderDiscovery}"
                          behaviors:DataGridSelectionPersistence.KeyProperties="Wallet,Type,Category,TimePeriod">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Snapshot UTC" Binding="{Binding SnapshotUtc}" Width="150" />
                        <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="90" />
                        <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="90" />
                        <DataGridTextColumn Header="Period" Binding="{Binding TimePeriod}" Width="80" />
                        <DataGridTextColumn Header="Rank" Binding="{Binding Rank}" Width="70" />
                        <DataGridTextColumn Header="User" Binding="{Binding UserName}" Width="150" />
                        <DataGridTextColumn Header="Wallet" Binding="{Binding Wallet}" Width="260" />
                        <DataGridTextColumn Header="PnL" Binding="{Binding Pnl}" Width="90" />
                        <DataGridTextColumn Header="Volume" Binding="{Binding Volume}" Width="100" />
                        <DataGridTextColumn Header="All PnL" Binding="{Binding AllTimePnl}" Width="90" />
                        <DataGridTextColumn Header="All Volume" Binding="{Binding AllTimeVolume}" Width="100" />
                        <DataGridCheckBoxColumn Header="Verified" Binding="{Binding Verified}" Width="80" />
                        <DataGridTextColumn Header="Trades" Binding="{Binding TradesFetched}" Width="70" />
                        <DataGridTextColumn Header="Buy" Binding="{Binding BuyTrades}" Width="60" />
                        <DataGridTextColumn Header="Sell" Binding="{Binding SellTrades}" Width="60" />
                        <DataGridTextColumn Header="Recent Vol" Binding="{Binding RecentTradeVolumeUsd}" Width="100" />
                        <DataGridTextColumn Header="Avg Trade" Binding="{Binding AverageTradeUsd}" Width="100" />
                        <DataGridTextColumn Header="Last Trade UTC" Binding="{Binding LastTradeUtc}" Width="150" />
                        <DataGridTextColumn Header="Positions" Binding="{Binding PositionsFetched}" Width="80" />
                        <DataGridTextColumn Header="Position Value" Binding="{Binding OpenPositionValueUsd}" Width="110" />
                        <DataGridTextColumn Header="Position PnL" Binding="{Binding OpenPositionCashPnlUsd}" Width="110" />
                        <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Onchain Trades">
                <DataGrid ItemsSource="{Binding OnChainTradeDetails}"
                          behaviors:DataGridSelectionPersistence.KeyProperties="TransactionHash,TokenId,Maker,Taker">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Timestamp UTC" Binding="{Binding TimestampUtc}" Width="150" />
                        <DataGridTextColumn Header="Market" Binding="{Binding Market}" Width="300" />
                        <DataGridTextColumn Header="Outcome" Binding="{Binding Outcome}" Width="100" />
                        <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="110" />
                        <DataGridTextColumn Header="Maker" Binding="{Binding Maker}" Width="250" />
                        <DataGridTextColumn Header="Taker" Binding="{Binding Taker}" Width="250" />
                        <DataGridTextColumn Header="Maker side" Binding="{Binding MakerSide}" Width="90" />
                        <DataGridTextColumn Header="Taker side" Binding="{Binding TakerSide}" Width="90" />
                        <DataGridTextColumn Header="Price" Binding="{Binding Price}" Width="80" />
                        <DataGridTextColumn Header="Shares" Binding="{Binding SizeShares}" Width="90" />
                        <DataGridTextColumn Header="Notional" Binding="{Binding NotionalUsd}" Width="90" />

{
  "Bot": {
    "Mode": "ReadOnly",
    "EnableLiveTrading": false
  },
  "PolymarketAuth": {
    "Enabled": false,
    "SecretProvider": "Environment",
    "SigningAddress": ""
  },
  "PaperTrading": {
    "InitialBankrollUsd": 10000,
    "DefaultOrderTtlSeconds": 300
  },
  "Risk": {
    "MaxTradeBankrollPct": 0.25,
    "MaxMarketBankrollPct": 1.0,
    "MaxTraderBankrollPct": 3.0,
    "MaxCategoryBankrollPct": 7.5,
    "MaxTotalDeployedPct": 25.0,
    "MaxDailyLossPct": 1.0,
    "MaxOpenOrders": 10,
    "MaxOrderAgeSeconds": 300
  },
  "Watchlist": {
    "Traders": []
  },
  "MarketDataWebSocket": {
    "Enabled": true,
    "MarketEndpointUrl": "wss://ws-subscriptions-clob.polymarket.com/ws/market",
    "HeartbeatSeconds": 10,
    "ReconnectBaseDelaySeconds": 2,
    "ReconnectMaxDelaySeconds": 60,
    "SubscriptionRefreshSeconds": 15,
    "StaleAfterSeconds": 30,
    "ReceiveBufferBytes": 65536,
    "StrongSignalMinimumScore": 90,
    "StrongSignalLookbackMinutes": 30,
    "MaxSubscribedAssets": 100,
    "PinnedAssetIds": []
  },
  "Storage": {
    "Provider": "PostgreSQL",
    "ConnectionString": "",
    "ConnectionStringEnvironmentVariable": "POLYCOPYTRADER_POSTGRES_CONNECTION",
    "RequireConfiguredDatabase": false
  },
  "Dashboard": {
    "RefreshIntervalSeconds": 3
  },
  "Analytics": {
    "DailyReportGenerationEnabled": true,
    "DailyReportRefreshMinutes": 15,
    "DashboardReportLimit": 250,
    "CsvExportDirectory": "exports"
  },
  "Ipc": {
    "Enabled": true,
    "ListenUrl": "http://127.0.0.1:5118/",
    "DashboardBaseUrl": "http://127.0.0.1:5118/"
  }
}
